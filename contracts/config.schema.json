{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Base Library Config",
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": {
      "type": "string"
    },
    "timeout_ms": {
      "type": "integer",
      "minimum": 0
    },
    "secret": {
      "type": "string"
    },
    "brokers": {
      "type": "array"
    },
    "client_id": {
      "type": "string"
    },
    "security": {
      "type": "object"
    },
    "producer": {
      "type": "object"
    },
    "consumer": {
      "type": "object"
    },
    "admin": {
      "type": "object"
    },
    "retry": {
      "type": "object"
    },
    "observability": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
